generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/** 广场与对外匿名可见语义（与 isPublic 双轨兼容，查询以本字段为准） */
enum ProjectVisibilityStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum SocialPlatform {
  WECHAT_OFFICIAL
  WECHAT_CHANNELS
  DOUYIN
  XIAOHONGSHU
  WEIBO
  BILIBILI
  X
  DISCORD
  REDDIT
}

enum ProjectUpdateSourceType {
  MANUAL
  GITHUB
  SOCIAL
  SYSTEM
  /** 官网 / 博客 / Changelog */
  OFFICIAL
  /** AI 生成或摘要（亦可配合 isAiGenerated） */
  AI
  /** 信息源抓取：官网页 */
  WEBSITE
  /** 信息源抓取：博客 */
  BLOG
  /** 信息源抓取：文档站 */
  DOCS
}

enum ClaimStatus {
  UNCLAIMED
  CLAIMED
}

/** 项目侧通知事件类型（站内轻通知 V1；后续可扩展 PR 同步等） */
enum ProjectNotificationEventType {
  UPDATE_POSTED
}

/** 自动发现候选项目状态：仅人工确认后再进入广场 */
enum DiscoveredProjectCandidateStatus {
  pending
  imported
  discarded
}

/** 项目外部信息源（与 Project.githubUrl / websiteUrl 并存，逐步收敛至此表） */
enum ProjectSourceKind {
  GITHUB
  GITEE
  WEBSITE
  DOCS
  BLOG
  TWITTER
  WECHAT
  XIAOHONGSHU
  DOUYIN
  ZHIHU
  BILIBILI
  DISCORD
  OTHER
}

/** Discovery V2：抓取来源开关 */
enum DiscoverySourceStatus {
  ACTIVE
  PAUSED
  DISABLED
}

/** Discovery V2：单次任务运行状态 */
enum DiscoveryRunStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

/** Discovery V2：候选补全状态（后续可接 enrichment 流水线） */
enum DiscoveryEnrichmentStatus {
  PENDING
  OK
  FAILED
}

/** Discovery V2：单次 Enrichment 任务状态 */
enum DiscoveryEnrichmentJobStatus {
  RUNNING
  SUCCESS
  FAILED
}

/** Discovery V2：规则分类流水线状态（候选侧建议值；ACCEPTED 表示已合并入 tags/categories） */
enum DiscoveryClassificationStatus {
  PENDING
  DONE
  FAILED
  ACCEPTED
}

/** Discovery V2：单次分类任务状态 */
enum DiscoveryClassificationJobStatus {
  RUNNING
  SUCCESS
  FAILED
}

/** Discovery V2：人工审核状态 */
enum DiscoveryReviewStatus {
  PENDING
  APPROVED
  REJECTED
  /** 运营忽略：不参与待办，可与 REJECTED 区分用途 */
  IGNORED
  MERGED
}

/** Discovery V2：是否已导入正式 Project */
enum DiscoveryImportStatus {
  PENDING
  IMPORTED
  SKIPPED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /** 手机号登录展示与查询；身份以 Account(provider=phone) 为准 */
  phone         String?   @unique

  accounts Account[]
  sessions Session[]

  createdProjects Project[] @relation("ProjectCreator")
  claimedProjects Project[] @relation("ProjectClaimer")
  /** 用户点赞的项目（热度信号；唯一约束在 ProjectLike） */
  projectLikes   ProjectLike[]
  /** 用户关注的项目；后续站内更新提醒 / 邮件订阅等可基于此查询 */
  projectFollows ProjectFollow[]
  /** 站内轻通知收件箱（关注项目动态等） */
  userNotifications UserNotification[]
  /** Discovery V2：审核记录的审核人 */
  discoveryCandidateReviews DiscoveryCandidate[] @relation("DiscoveryCandidateReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** Discovery V2：可配置的抓取来源（GitHub Topic / Trending 等） */
model DiscoverySource {
  id              String                @id @default(cuid())
  key             String                @unique
  name            String
  type            String
  subtype         String?
  status          DiscoverySourceStatus @default(ACTIVE)
  configJson      Json?
  scheduleCron    String?
  lastRunAt       DateTime?
  lastSuccessAt   DateTime?
  lastErrorAt     DateTime?
  lastErrorMessage String?              @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  runs       DiscoveryRun[]
  candidates DiscoveryCandidate[]

  @@index([type, status])
}

/** Discovery V2：单次抓取审计日志 */
model DiscoveryRun {
  id                    String             @id @default(cuid())
  sourceId              String
  source                DiscoverySource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status                DiscoveryRunStatus   @default(RUNNING)
  startedAt             DateTime           @default(now())
  finishedAt            DateTime?
  fetchedCount          Int                @default(0)
  parsedCount           Int                @default(0)
  newCandidateCount     Int                @default(0)
  updatedCandidateCount Int                @default(0)
  importedProjectCount  Int                @default(0)
  skippedCount          Int                @default(0)
  logJson               Json?
  errorMessage          String?            @db.Text
  createdAt             DateTime           @default(now())

  candidates DiscoveryCandidate[]

  @@index([sourceId, startedAt(sort: Desc)])
}

/** Discovery V2：候选池（不入广场直至审核导入） */
model DiscoveryCandidate {
  id               String                    @id @default(cuid())
  sourceId         String
  source           DiscoverySource           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  discoveryRunId   String?
  discoveryRun     DiscoveryRun?             @relation(fields: [discoveryRunId], references: [id], onDelete: SetNull)

  externalType     String
  externalId       String?
  externalUrl      String?
  sourceKey        String?
  normalizedKey    String?                   @unique
  dedupeHash       String?                   @unique

  title            String
  slugCandidate    String?
  summary          String?                   @db.Text
  descriptionRaw   String?                   @db.Text
  website          String?
  repoUrl          String?
  docsUrl          String?
  twitterUrl       String?
  wechatUrl       String?
  douyinUrl        String?
  xiaohongshuUrl  String?
  youtubeUrl      String?

  language           String?
  openSourceLicense String?
  stars             Int                      @default(0)
  forks             Int                      @default(0)
  watchers          Int                      @default(0)
  issues            Int                      @default(0)
  lastCommitAt      DateTime?
  repoCreatedAt     DateTime?
  repoUpdatedAt     DateTime?

  ownerName      String?
  ownerUrl       String?
  avatarUrl      String?

  categoriesJson  Json?
  tagsJson        Json?
  metadataJson    Json?
  rawPayloadJson  Json?

  /** 规则分类 V1：建议主类型（单值） */
  suggestedType               String?
  /** 规则分类 V1：建议标签（string[]） */
  suggestedTagsJson           Json?
  classificationStatus        DiscoveryClassificationStatus  @default(PENDING)
  classificationScore         Float?
  /** 可读依据，如 matched topic: llm */
  classificationEvidenceJson  Json?
  isAiRelated                 Boolean?
  isChineseTool               Boolean?

  enrichmentStatus DiscoveryEnrichmentStatus @default(PENDING)
  reviewStatus     DiscoveryReviewStatus     @default(PENDING)
  importStatus     DiscoveryImportStatus     @default(PENDING)

  matchedProjectId String?
  matchedProject   Project?                  @relation("DiscoveryCandidateMatchedProject", fields: [matchedProjectId], references: [id], onDelete: SetNull)

  score             Float?
  qualityScore      Float?
  popularityScore   Float?
  freshnessScore    Float?

  /** 后台审核排序用规则分（可解释因子见 reviewPrioritySignals） */
  reviewPriorityScore   Float                       @default(0)
  reviewPrioritySignals Json?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  reviewedById String?
  reviewedBy    User?    @relation("DiscoveryCandidateReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  reviewNote    String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /** 若本候选通过「新建 Project」导入，对应 Project 上的回溯字段指向本条 */
  importedAsOriginProject Project? @relation("ImportedProjectFromCandidate")

  enrichmentJobs       DiscoveryEnrichmentJob[]
  enrichmentLinks      DiscoveryEnrichmentLink[]
  classificationJobs   DiscoveryClassificationJob[]

  @@index([sourceId, lastSeenAt(sort: Desc)])
  @@index([suggestedType])
  @@index([isAiRelated])
  @@index([isChineseTool])
  @@index([classificationStatus])
  @@index([reviewStatus, importStatus])
  @@index([reviewStatus, reviewPriorityScore(sort: Desc)])
  @@index([repoUrl])
  @@index([matchedProjectId])
}

/** Discovery V2：候选 Enrichment 任务（审计；不落原始 HTML） */
model DiscoveryEnrichmentJob {
  id             String                       @id @default(cuid())
  candidateId    String
  candidate      DiscoveryCandidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  source         String                       @default("enrichment-v1")
  status         DiscoveryEnrichmentJobStatus @default(RUNNING)
  startedAt      DateTime                     @default(now())
  finishedAt     DateTime?
  extractedCount Int                          @default(0)
  errorMessage   String?                      @db.Text
  logJson        Json?
  createdAt      DateTime                     @default(now())

  links DiscoveryEnrichmentLink[]

  @@index([candidateId, startedAt(sort: Desc)])
}

/** Discovery V2：单次规则分类任务（审计日志） */
model DiscoveryClassificationJob {
  id           String                           @id @default(cuid())
  candidateId  String
  candidate    DiscoveryCandidate               @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status       DiscoveryClassificationJobStatus @default(RUNNING)
  startedAt    DateTime                         @default(now())
  finishedAt   DateTime?
  errorMessage String?                          @db.Text
  logJson      Json?
  createdAt    DateTime                         @default(now())

  @@index([candidateId, startedAt(sort: Desc)])
}

/** Discovery V2：Enrichment 抽取的外链（需人工 Accept 后写回候选字段） */
model DiscoveryEnrichmentLink {
  id            String   @id @default(cuid())
  candidateId   String
  candidate     DiscoveryCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId         String?
  job           DiscoveryEnrichmentJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  platform      String
  url           String
  normalizedUrl String
  host          String?
  source        String
  confidence    Float
  isPrimary     Boolean  @default(false)
  isAccepted    Boolean  @default(false)
  evidenceText  String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateId, normalizedUrl])
  @@index([candidateId])
  @@index([jobId])
}

/** Discovery V2：项目外链（与 ProjectSource 并存；审核导入时写入） */
model ProjectExternalLink {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  platform  String
  url       String
  label     String?
  isPrimary Boolean  @default(false)
  isVerified Boolean @default(false)
  source    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([platform, projectId])
}

/** GitHub 等来源自动发现的待导入项目（不入广场直至人工导入） */
model DiscoveredProjectCandidate {
  id           String                           @id @default(cuid())
  source       String
  sourceId     String
  sourceUrl    String
  name         String
  description  String?                          @db.Text
  ownerName    String
  repoUrl      String
  homepageUrl  String?
  stars        Int                              @default(0)
  primaryLanguage String?
  lastPushedAt DateTime?
  /** V1 启发式「可能与中国团队相关」，非精准识别 */
  isChineseRelated Boolean                       @default(false)
  status       DiscoveredProjectCandidateStatus  @default(pending)
  rawPayload   Json?
  discoveredAt DateTime                         @default(now())
  updatedAt    DateTime                         @updatedAt

  @@unique([source, sourceId])
  @@index([status, discoveredAt(sort: Desc)])
}

/** NextAuth.js / Auth.js OAuth 账户关联 */
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/** 数据库会话（与 JWT 策略并存时由适配器预留；可留空） */
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/** 手机号验证码（仅存储 hash；用于登录等场景扩展 purpose） */
model PhoneVerificationCode {
  id             String    @id @default(cuid())
  phone          String
  codeHash       String
  purpose        String
  expiresAt      DateTime
  consumedAt     DateTime?
  /** 校验失败次数；达到上限后视为作废（需重新获取验证码） */
  verifyAttempts Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([phone, purpose, createdAt])
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  tagline     String?
  description String?
  /** AI 等处写入的轻量标签（导入项目等） */
  tags        String[]      @default([])
  /** Discovery 分类接受后的类目列表（JSON string[]，与候选 categoriesJson 对齐） */
  categoriesJson Json?
  /** 主类型/首类目，便于广场筛选与卡片展示（导入时由 categoriesJson[0] 写入） */
  primaryCategory String?
  /** Discovery 规则分类接受后写入；仅 null 时由导入合并补齐，不强行覆盖 false */
  isAiRelated     Boolean?
  isChineseTool   Boolean?
  /** 运营脚本 / AI 生成的详情页摘要卡（hero 下） */
  aiCardSummary String?
  logoUrl     String?
  websiteUrl  String?
  githubUrl   String?
  /** 种子/运营标记：广场当前列表不按此排序，仅预留 */
  isFeatured   Boolean       @default(false)
  /** 数据来源占位，如 seed、manual */
  sourceType   String?
  status       ProjectStatus @default(ACTIVE)
  /** 历史字段；发布/隐藏动作与 visibilityStatus 同步 */
  isPublic     Boolean                 @default(false)
  visibilityStatus ProjectVisibilityStatus @default(DRAFT)
  claimStatus  ClaimStatus             @default(UNCLAIMED)
  claimedAt    DateTime?
  /** 展示用：如 owner/repo，与 GitHub 认领校验一致 */
  claimedBy    String?
  createdById     String?
  createdBy       User?   @relation("ProjectCreator", fields: [createdById], references: [id])
  claimedByUserId String?
  claimedByUser   User?   @relation("ProjectClaimer", fields: [claimedByUserId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  /** 非空表示已软删除；广场与详情不显；slug 仍占用直至恢复或未来硬删 */
  deletedAt    DateTime?

  /** Discovery V2：溯源（人工审核导入后写入） */
  discoverySource           String?
  discoverySourceId         String?
  discoveredAt              DateTime?
  importedFromCandidateId   String?         @unique
  importedFromCandidate     DiscoveryCandidate? @relation("ImportedProjectFromCandidate", fields: [importedFromCandidateId], references: [id], onDelete: SetNull)

  externalLinks ProjectExternalLink[]
  discoveryMatches DiscoveryCandidate[] @relation("DiscoveryCandidateMatchedProject")

  socialAccounts    ProjectSocialAccount[]
  sources           ProjectSource[]
  updates           ProjectUpdate[]
  githubSnapshots   GithubRepoSnapshot[]
  weeklySummaries   ProjectWeeklySummary[]
  likes             ProjectLike[]
  followers         ProjectFollow[]
  notificationEvents  ProjectNotificationEvent[]
  userInboxNotifications UserNotification[]

  @@index([createdById])
  @@index([claimedByUserId])
  @@index([deletedAt])
  @@index([primaryCategory])
  @@index([isAiRelated])
  @@index([isChineseTool])
}

/** 项目点赞（每用户每项目至多一条） */
model ProjectLike {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

/**
 * 关注项目（每用户每项目至多一条）。
 * 未来可扩展：站内动态提醒、邮件订阅、用户「已关注项目」列表等，请通过本表查询而非一次性逻辑。
 */
model ProjectFollow {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

/** AI 多源动态周总结（由定时脚本写入，项目页展示最新一条） */
model ProjectWeeklySummary {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  summary   String   @db.Text
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
}

model ProjectSource {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      ProjectSourceKind
  url       String
  label     String?
  isPrimary Boolean           @default(false)
  createdAt DateTime          @default(now())

  @@index([projectId])
}

model ProjectSocialAccount {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  accountName String
  accountUrl  String?
  createdAt   DateTime       @default(now())

  @@index([projectId])
}

model ProjectUpdate {
  id          String                  @id @default(cuid())
  projectId   String
  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType  ProjectUpdateSourceType
  /** 展示用来源文案（覆盖默认映射时） */
  sourceLabel String?
  title       String
  summary     String?
  content     String?
  sourceUrl   String?
  /** 插件/同步扩展字段（JSON 文本） */
  metaJson    String?
  isAiGenerated Boolean               @default(false)
  occurredAt  DateTime?
  createdAt   DateTime                @default(now())
  /** 由本条动态触发的站内通知事件（可空：动态删除时事件保留但脱钩） */
  notificationEvents ProjectNotificationEvent[]

  @@index([projectId])
}

/** 项目侧「可通知」事件一条；向所有关注用户 fan-out 为 UserNotification */
model ProjectNotificationEvent {
  id               String                        @id @default(cuid())
  projectId        String
  type             ProjectNotificationEventType
  title            String
  message          String                        @db.Text
  sourceUpdateId   String?
  project          Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceUpdate     ProjectUpdate?                @relation(fields: [sourceUpdateId], references: [id], onDelete: SetNull)
  createdAt        DateTime                      @default(now())
  recipientRecords UserNotification[]

  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([sourceUpdateId])
}

/** 用户收件箱：一条对应一个 ProjectNotificationEvent，读状态独立 */
model UserNotification {
  id                        String                   @id @default(cuid())
  userId                    String
  projectNotificationEventId String
  projectId                 String
  readAt                    DateTime?
  createdAt                 DateTime                 @default(now())
  user                      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event                     ProjectNotificationEvent @relation(fields: [projectNotificationEventId], references: [id], onDelete: Cascade)
  project                   Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectNotificationEventId])
  @@index([userId])
  @@index([userId, readAt])
  @@index([projectId])
}

model GithubRepoSnapshot {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repoPlatform      String?
  repoOwner         String?
  repoName          String?
  repoFullName      String
  defaultBranch     String?
  stars             Int       @default(0)
  forks             Int       @default(0)
  openIssues        Int       @default(0)
  watchers          Int       @default(0)
  commitCount7d     Int       @default(0)
  commitCount30d    Int       @default(0)
  contributorsCount Int       @default(0)
  lastCommitAt      DateTime?
  latestReleaseTag  String?
  latestReleaseAt   DateTime?
  fetchedAt         DateTime  @default(now())

  @@index([projectId])
}
