generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SocialPlatform {
  WECHAT_OFFICIAL
  WECHAT_CHANNELS
  DOUYIN
  XIAOHONGSHU
  WEIBO
  BILIBILI
  X
  DISCORD
  REDDIT
}

enum ProjectUpdateSourceType {
  MANUAL
  GITHUB
  SOCIAL
  SYSTEM
  /** 官网 / 博客 / Changelog */
  OFFICIAL
  /** AI 生成或摘要（亦可配合 isAiGenerated） */
  AI
  /** 信息源抓取：官网页 */
  WEBSITE
  /** 信息源抓取：博客 */
  BLOG
  /** 信息源抓取：文档站 */
  DOCS
}

enum ClaimStatus {
  UNCLAIMED
  CLAIMED
}

/** 项目外部信息源（与 Project.githubUrl / websiteUrl 并存，逐步收敛至此表） */
enum ProjectSourceKind {
  GITHUB
  GITEE
  WEBSITE
  DOCS
  BLOG
  TWITTER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /** 手机号登录展示与查询；身份以 Account(provider=phone) 为准 */
  phone         String?   @unique

  accounts Account[]
  sessions Session[]

  createdProjects Project[] @relation("ProjectCreator")
  claimedProjects Project[] @relation("ProjectClaimer")
  /** 用户点赞的项目（热度信号；唯一约束在 ProjectLike） */
  projectLikes   ProjectLike[]
  /** 用户关注的项目；后续站内更新提醒 / 邮件订阅等可基于此查询 */
  projectFollows ProjectFollow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** NextAuth.js / Auth.js OAuth 账户关联 */
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/** 数据库会话（与 JWT 策略并存时由适配器预留；可留空） */
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/** 手机号验证码（仅存储 hash；用于登录等场景扩展 purpose） */
model PhoneVerificationCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose, createdAt])
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  tagline     String?
  description String?
  /** AI 等处写入的轻量标签（导入项目等） */
  tags        String[]      @default([])
  /** 运营脚本 / AI 生成的详情页摘要卡（hero 下） */
  aiCardSummary String?
  logoUrl     String?
  websiteUrl  String?
  githubUrl   String?
  /** 种子/运营标记：广场当前列表不按此排序，仅预留 */
  isFeatured   Boolean       @default(false)
  /** 数据来源占位，如 seed、manual */
  sourceType   String?
  status       ProjectStatus @default(ACTIVE)
  isPublic     Boolean       @default(true)
  claimStatus  ClaimStatus   @default(UNCLAIMED)
  claimedAt    DateTime?
  /** 展示用：如 owner/repo，与 GitHub 认领校验一致 */
  claimedBy    String?
  createdById     String?
  createdBy       User?   @relation("ProjectCreator", fields: [createdById], references: [id])
  claimedByUserId String?
  claimedByUser   User?   @relation("ProjectClaimer", fields: [claimedByUserId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  socialAccounts    ProjectSocialAccount[]
  sources           ProjectSource[]
  updates           ProjectUpdate[]
  githubSnapshots   GithubRepoSnapshot[]
  weeklySummaries   ProjectWeeklySummary[]
  likes             ProjectLike[]
  followers         ProjectFollow[]

  @@index([createdById])
  @@index([claimedByUserId])
}

/** 项目点赞（每用户每项目至多一条） */
model ProjectLike {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

/**
 * 关注项目（每用户每项目至多一条）。
 * 未来可扩展：站内动态提醒、邮件订阅、用户「已关注项目」列表等，请通过本表查询而非一次性逻辑。
 */
model ProjectFollow {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

/** AI 多源动态周总结（由定时脚本写入，项目页展示最新一条） */
model ProjectWeeklySummary {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  summary   String   @db.Text
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
}

model ProjectSource {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      ProjectSourceKind
  url       String
  label     String?
  isPrimary Boolean           @default(false)
  createdAt DateTime          @default(now())

  @@index([projectId])
}

model ProjectSocialAccount {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  accountName String
  accountUrl  String?
  createdAt   DateTime       @default(now())

  @@index([projectId])
}

model ProjectUpdate {
  id          String                  @id @default(cuid())
  projectId   String
  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType  ProjectUpdateSourceType
  /** 展示用来源文案（覆盖默认映射时） */
  sourceLabel String?
  title       String
  summary     String?
  content     String?
  sourceUrl   String?
  /** 插件/同步扩展字段（JSON 文本） */
  metaJson    String?
  isAiGenerated Boolean               @default(false)
  occurredAt  DateTime?
  createdAt   DateTime                @default(now())

  @@index([projectId])
}

model GithubRepoSnapshot {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repoPlatform      String?
  repoOwner         String?
  repoName          String?
  repoFullName      String
  defaultBranch     String?
  stars             Int       @default(0)
  forks             Int       @default(0)
  openIssues        Int       @default(0)
  watchers          Int       @default(0)
  commitCount7d     Int       @default(0)
  commitCount30d    Int       @default(0)
  contributorsCount Int       @default(0)
  lastCommitAt      DateTime?
  latestReleaseTag  String?
  latestReleaseAt   DateTime?
  fetchedAt         DateTime  @default(now())

  @@index([projectId])
}
