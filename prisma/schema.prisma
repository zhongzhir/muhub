generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SocialPlatform {
  WECHAT_OFFICIAL
  WECHAT_CHANNELS
  DOUYIN
  XIAOHONGSHU
  WEIBO
  BILIBILI
  X
  DISCORD
  REDDIT
}

enum ProjectUpdateSourceType {
  MANUAL
  GITHUB
  SOCIAL
  SYSTEM
  /** 官网 / 博客 / Changelog */
  OFFICIAL
  /** AI 生成或摘要（亦可配合 isAiGenerated） */
  AI
}

enum ClaimStatus {
  UNCLAIMED
  CLAIMED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  tagline     String?
  description String?
  /** AI 等处写入的轻量标签（导入项目等） */
  tags        String[]      @default([])
  /** 运营脚本 / AI 生成的详情页摘要卡（hero 下） */
  aiCardSummary String?
  logoUrl     String?
  websiteUrl  String?
  githubUrl   String?
  /** 种子/运营标记：广场当前列表不按此排序，仅预留 */
  isFeatured   Boolean       @default(false)
  /** 数据来源占位，如 seed、manual */
  sourceType   String?
  status       ProjectStatus @default(ACTIVE)
  isPublic     Boolean       @default(true)
  claimStatus  ClaimStatus   @default(UNCLAIMED)
  claimedAt    DateTime?
  claimedBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  socialAccounts  ProjectSocialAccount[]
  updates         ProjectUpdate[]
  githubSnapshots GithubRepoSnapshot[]
}

model ProjectSocialAccount {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  accountName String
  accountUrl  String?
  createdAt   DateTime       @default(now())

  @@index([projectId])
}

model ProjectUpdate {
  id          String                  @id @default(cuid())
  projectId   String
  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType  ProjectUpdateSourceType
  /** 展示用来源文案（覆盖默认映射时） */
  sourceLabel String?
  title       String
  summary     String?
  content     String?
  sourceUrl   String?
  /** 插件/同步扩展字段（JSON 文本） */
  metaJson    String?
  isAiGenerated Boolean               @default(false)
  occurredAt  DateTime?
  createdAt   DateTime                @default(now())

  @@index([projectId])
}

model GithubRepoSnapshot {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repoPlatform      String?
  repoOwner         String?
  repoName          String?
  repoFullName      String
  defaultBranch     String?
  stars             Int       @default(0)
  forks             Int       @default(0)
  openIssues        Int       @default(0)
  watchers          Int       @default(0)
  commitCount7d     Int       @default(0)
  commitCount30d    Int       @default(0)
  contributorsCount Int       @default(0)
  lastCommitAt      DateTime?
  latestReleaseTag  String?
  latestReleaseAt   DateTime?
  fetchedAt         DateTime  @default(now())

  @@index([projectId])
}
