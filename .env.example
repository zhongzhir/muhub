# 上线必配（示例留空，复制为 .env 后填写）
DATABASE_URL=
OPENAI_API_KEY=

# 站点 URL（OG、规范链等；端口应与下方 AUTH_URL / NEXTAUTH_URL 一致）
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js / NextAuth v5 会话与 GitHub 登录（勿泄露到前端）
# 生成随机串：openssl rand -base64 32
AUTH_SECRET=
# 与 NEXTAUTH_SECRET 等价，任选其一配置即可
# NEXTAUTH_SECRET=

# —— OAuth 回调与端口（解决 GitHub「redirect_uri is not associated」）——
# Auth.js 优先读 AUTH_URL；务必与 NEXTAUTH_URL 填同一 origin（含端口），并与浏览器访问地址一致。
# 本地示例：pnpm dev 默认 3000；若使用 3005，则三者都改为 :3005。
# GitHub OAuth App：https://github.com/settings/developers
# 类型须为「OAuth Apps」（不是 GitHub Apps）；在应用详情页核对 Client ID 与 .env 里填的完全一致。
#
# 「Authorization callback URL」必须与浏览器最终站点的 origin 逐字一致（https / 是否带 www / 路径 / 末尾无多余斜杠）。
# www 与 apex 是两条不同 URL，只填一种而实际 redirect_uri 另一种是 GitHub 报错
# “redirect_uri is not associated with this application” 的常见原因。
# 生产示例（建议四条都加上，避免遗漏）：
#   https://www.muhub.cn/api/auth/callback/github
#   https://muhub.cn/api/auth/callback/github
# 本地示例（可同时添加多条）：
#   http://localhost:3000/api/auth/callback/github
#   http://localhost:3005/api/auth/callback/github
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth（任选一套命名，代码已做兼容）
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
GITHUB_ID=
GITHUB_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NEXTAUTH_SECRET=  # 可与上方 AUTH_SECRET 相同，只需配一种即可

# 生产环境将 AUTH_URL / NEXTAUTH_URL 改为线上 https origin（与 GitHub 回调的第一段域名一致，例如 www 不可省略）
# AUTH_URL="https://www.muhub.cn"
# NEXTAUTH_URL="https://www.muhub.cn"
# Vercel 项目 Environment Variables 中同上；可再设 AUTH_TRUST_HOST=true
# AUTH_TRUST_HOST=true

GITHUB_TOKEN=""

# Product Hunt GraphQL API v2（Discovery 来源 producthunt-*）；读公开数据需 Developer Token
# https://api.producthunt.com/v2/docs
PRODUCTHUNT_ACCESS_TOKEN=

# Discovery V2 管理后台 /admin：允许的 User.id（cuid），逗号或空格分隔；务必在生产环境配置
MUHUB_ADMIN_USER_IDS=

# 本地可选：true 时任意已登录用户可访问 /admin（禁止用于生产）
# MUHUB_ADMIN_DEV_ALLOW_ALL=true

# 内部 HTTP 触发项目发现：GET /api/internal/discovery?secret=…（openssl rand -base64 32）
DISCOVERY_SECRET=

# 手机号验证码登录（默认开启；设为 false 可关闭登录页入口与发码接口）
# PHONE_LOGIN_ENABLED=true

# 与 AUTH_SECRET 共用即可；亦可单独配置以增强验证码 hash
# PHONE_CODE_PEPPER=

# Playwright E2E：与 AUTH_SECRET 同时配置后，需登录的用例会调用 POST /api/e2e/auth-token 注入会话（勿提交真实生产密钥）
# E2E_TEST_SECRET=
# CI 工作流中已写死占位值；本地跑全量 e2e 时请自行生成并加入 .env

# 可选：OpenAI 兼容网关与模型（默认 https://api.openai.com + gpt-4o-mini）
# OPENAI_BASE_URL="https://api.openai.com"
# OPENAI_MODEL="gpt-4o-mini"

# 可选：Playwright / CI 导入与刷新走 fixture，无需访问 api.github.com
# GITHUB_IMPORT_E2E_FIXTURE=1
# GITHUB_REFRESH_E2E_FIXTURE=1
