# 上线必配（示例留空，复制为 .env 后填写）
DATABASE_URL=
OPENAI_API_KEY=
NEXTAUTH_SECRET=

NEXT_PUBLIC_APP_URL="http://localhost:3000"
GITHUB_TOKEN=""

# 可选：OpenAI 兼容网关与模型（默认 https://api.openai.com + gpt-4o-mini）
# OPENAI_BASE_URL="https://api.openai.com"
# OPENAI_MODEL="gpt-4o-mini"

# NEXTAUTH_SECRET：若后续接入 NextAuth 用于会话签名；当前 V1 无登录亦可先占位，勿泄露到前端。

# 可选：Playwright / CI 导入与刷新走 fixture，无需访问 api.github.com
# GITHUB_IMPORT_E2E_FIXTURE=1
# GITHUB_REFRESH_E2E_FIXTURE=1
