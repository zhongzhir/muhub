# 上线必配（示例留空，复制为 .env 后填写）
DATABASE_URL=
OPENAI_API_KEY=

# 站点 URL（OG、规范链等，与 AUTH_URL 可一致）
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js / NextAuth v5 会话与 GitHub 登录（勿泄露到前端）
# 生成随机串：openssl rand -base64 32
AUTH_SECRET=
# 与 NEXTAUTH_SECRET 等价，任选其一配置即可
# NEXTAUTH_SECRET=

# GitHub OAuth App：https://github.com/settings/developers
# Callback URL 示例：http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# 生产环境填完整站点 origin；Vercel 可再设 AUTH_TRUST_HOST=true
# AUTH_URL="https://你的域名"
# AUTH_TRUST_HOST=true

GITHUB_TOKEN=""

# 手机号验证码登录（默认开启；设为 false 可关闭登录页入口与发码接口）
# PHONE_LOGIN_ENABLED=true

# 与 AUTH_SECRET 共用即可；亦可单独配置以增强验证码 hash
# PHONE_CODE_PEPPER=

# Playwright E2E：与 AUTH_SECRET 同时配置后，需登录的用例会调用 POST /api/e2e/auth-token 注入会话（勿提交真实生产密钥）
# E2E_TEST_SECRET=
# CI 工作流中已写死占位值；本地跑全量 e2e 时请自行生成并加入 .env

# 可选：OpenAI 兼容网关与模型（默认 https://api.openai.com + gpt-4o-mini）
# OPENAI_BASE_URL="https://api.openai.com"
# OPENAI_MODEL="gpt-4o-mini"

# 可选：Playwright / CI 导入与刷新走 fixture，无需访问 api.github.com
# GITHUB_IMPORT_E2E_FIXTURE=1
# GITHUB_REFRESH_E2E_FIXTURE=1
