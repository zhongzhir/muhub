# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# V1.1 Growth：本地待导入队列（可选落盘，不提交实际数据）
data/pending-external-imports.json

# V1.2 Content Agent：本地草稿（可迁移 DB）
data/content-drafts.json

# Content Agent V1：编排层资产包（与 growth 的 content-bundles 分立）
data/content-agent-bundles.json

# V1.3 Growth：内容资产包（可迁移 DB）
data/content-bundles.json
